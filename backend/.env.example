AZURE_TENANT_ID=<AZURE_TENANT_ID>
AZURE_CLIENT_ID=<AZURE_CLIENT_ID>
AZURE_CLIENT_SECRET=<AZURE_CLIENT_SECRET>

# Generate with: node -e "require('crypto').randomBytes(32).toString('hex')" | Write-Host
# Must match VITE_API_KEY in frontend/.env
API_KEY=<API_KEY>

# Azure DevOps PAT — needed for the Pipeline Health Dashboard.
# Generate at: https://dev.azure.com → User Settings → Personal Access Tokens
# Required scope: Build (Read)
AZURE_DEVOPS_PAT=<AZURE_DEVOPS_PAT>

# In production, set this to your frontend's exact origin to restrict CORS.
# In development, any localhost origin is allowed by default.
# FRONTEND_URL=https://your-app.example.com
