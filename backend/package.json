{
  "name": "vantage-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "test": "ts-node src/__tests__/pasteparse.test.ts && ts-node src/__tests__/optimizer.test.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "package": "npx @yao-pkg/pkg dist/index.js --targets node20-win-x64 --output ../vantage.exe"
  },
  "pkg": {
    "targets": ["node20-win-x64"]
  },
  "dependencies": {
    "@azure/msal-node": "^5.2.3",
    "axios": "^1.17.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
