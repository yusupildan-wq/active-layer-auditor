{
  "name": "vantage-electron",
  "version": "1.0.0",
  "description": "Vantage – Power Platform Engineering Toolkit",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --publish never"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.vantage.app",
    "productName": "Vantage",
    "copyright": "Copyright © 2025 Vantage",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "assets/**"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": ["**/*"]
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../frontend/dist",
        "to": "public",
        "filter": ["**/*"]
      },
      {
        "from": "../config",
        "to": "config",
        "filter": ["**/*"]
      }
    ],
    "publish": {
      "provider": "github",
      "owner": "yusupildan-wq",
      "repo": "Vantage"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vantage",
      "differentialPackage": false
    }
  }
}
